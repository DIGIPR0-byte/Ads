          model:"claude-sonnet-4-20250514", max_tokens:1000,
          system:"You are a world-class digital product copywriter. Return ONLY valid JSON, no markdown, no backticks.",
          messages:[{role:"user",content:`Create 3 ad variations for this digital product.
Product: ${product.name}
Description: ${product.desc}
Price: ${product.price||"not specified"}
Target audience: ${product.audience||"general"}
