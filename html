          </div>
        )}

        {/* ── STEP 1 ── */}
        {step===1&&generatedAds&&(
          <div className="fade-in">
            <div style={{marginBottom:20}}>
              <div style={{fontFamily:"'Syne',sans-serif",fontSize:22,fontWeight:800}}>
                Pick your <span style={{color:"#f97316"}}>ad copy</span>
              </div>
              <div style={{color:"#666",fontSize:13,marginTop:6}}>3 variations. Select one to continue.</div>
            </div>
            <div style={{display:"flex",flexDirection:"column",gap:12}}>
              {generatedAds.map((a,i)=>(
                <div key={i} className={`ad-card ${selectedAd===i?"active":""}`} onClick={()=>setSelectedAd(i)}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:10}}>
                    <div style={{fontSize:11,color:selectedAd===i?"#f97316":"#555",textTransform:"uppercase",letterSpacing:"1px",fontWeight:600}}>Variant {i+1}</div>
                    {selectedAd===i&&<div style={{fontSize:11,background:"rgba(249,115,22,.2)",color:"#f97316",padding:"2px 8px",borderRadius:20}}>Selected</div>}
                  </div>
                  <div style={{fontFamily:"'Syne',sans-serif",fontWeight:800,fontSize:18,lineHeight:1.3,marginBottom:6}}>{a.headline}</div>
                  <div style={{color:"#aaa",fontSize:13,marginBottom:10}}>{a.subheadline}</div>
                  <div style={{color:"#777",fontSize:12,lineHeight:1.6,borderTop:"1px solid rgba(255,255,255,.06)",paddingTop:10}}>{a.body}</div>
                  <div style={{marginTop:12,display:"flex",gap:8,alignItems:"center",flexWrap:"wrap"}}>
                    <div style={{background:"linear-gradient(135deg,#f97316,#ec4899)",padding:"5px 14px",borderRadius:20,fontSize:11,fontWeight:700,fontFamily:"'Syne',sans-serif"}}>{a.cta}</div>
                    <div style={{fontSize:11,color:"#555"}}>{a.hashtags?.slice(0,3).map(h=>`#${h}`).join(" ")}</div>
                  </div>
                </div>
              ))}
            </div>
            <div style={{marginTop:20}}>
              <div style={{fontSize:11,color:"#888",marginBottom:10,textTransform:"uppercase",letterSpacing:"1px"}}>Visual Preview</div>
              <div className="preview-card" style={{background:GRADIENTS[selectedGrad]}}>
                <div className="preview-overlay"/>
                <div style={{position:"relative",zIndex:1}}>
                  <div style={{fontSize:11,opacity:.7,marginBottom:8,textTransform:"uppercase",letterSpacing:"2px"}}>Digital Product</div>
                  <div style={{fontFamily:"'Syne',sans-serif",fontWeight:800,fontSize:24,lineHeight:1.2,marginBottom:8}}>{ad?.headline}</div>
                  <div style={{fontSize:13,opacity:.8,marginBottom:16}}>{ad?.subheadline}</div>
                  <div style={{background:"white",color:"#111",padding:"8px 20px",borderRadius:30,fontSize:12,fontWeight:700,display:"inline-block",fontFamily:"'Syne',sans-serif"}}>{ad?.cta}</div>
                  {product.price&&<div style={{position:"absolute",top:-80,right:0,background:"rgba(255,255,255,.15)",backdropFilter:"blur(10px)",padding:"8px 14px",borderRadius:10,fontSize:14,fontWeight:700}}>{product.price}</div>}
                </div>
              </div>
              <div style={{display:"flex",gap:8,marginTop:10,flexWrap:"wrap"}}>
                {GRADIENTS.map((g,i)=>(
                  <div key={i} onClick={()=>setSelectedGrad(i)}
                    style={{width:32,height:32,borderRadius:8,background:g,cursor:"pointer",
                      border:selectedGrad===i?"2px solid white":"2px solid transparent",transition:"all .2s"}}/>
                ))}
              </div>
            </div>
            <div style={{display:"flex",gap:12,marginTop:28}}>
              <button className="btn-ghost" onClick={()=>setStep(0)}>← Back</button>
              <button className="btn-primary" style={{flex:1,padding:"14px"}} onClick={()=>setStep(2)}>Next: Visuals →</button>
            </div>
          </div>
        )}

        {/* ── STEP 2 ── */}
        {step===2&&(
          <div className="fade-in">
            <div style={{marginBottom:20}}>
              <div style={{fontFamily:"'Syne',sans-serif",fontSize:22,fontWeight:800}}>
                Visual <span style={{color:"#f97316"}}>strategy</span>
              </div>
              <div style={{color:"#666",fontSize:13,marginTop:6}}>AI prompts for Midjourney, DALL-E, or Canva.</div>
            </div>
            <div className="card" style={{marginBottom:16}}>
              <div style={{fontSize:11,color:"#888",marginBottom:10,textTransform:"uppercase",letterSpacing:"1px"}}>Image Direction Hint</div>
              <input className="input-field" value={imagePrompt} onChange={e=>setImagePrompt(e.target.value)} placeholder="Describe the visual style or mood…"/>
              <button className="btn-primary" style={{marginTop:12,width:"100%"}} onClick={generateImageIdeas} disabled={generatingImg}>
                {generatingImg?"⚡ Thinking…":"Generate Visual Concepts →"}
              </button>
            </div>
            {imageIdeas&&(
              <div style={{display:"flex",flexDirection:"column",gap:12}} className="fade-in">
                {imageIdeas.map((img,i)=>(
                  <div key={i} className="card">
                    <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
                      <div style={{fontFamily:"'Syne',sans-serif",fontWeight:700,fontSize:15}}>{img.title}</div>
                      <div style={{display:"flex",gap:6}}>
                        <div style={{fontSize:11,background:"rgba(249,115,22,.15)",color:"#f97316",padding:"3px 10px",borderRadius:20}}>{img.style}</div>
                        <div style={{fontSize:11,background:"rgba(255,255,255,.06)",color:"#aaa",padding:"3px 10px",borderRadius:20}}>{img.mood}</div>
                      </div>
                    </div>
                    <div style={{color:"#888",fontSize:13,lineHeight:1.6,marginBottom:12}}>{img.description}</div>
                    <div style={{background:"rgba(0,0,0,.3)",border:"1px solid rgba(255,255,255,.08)",borderRadius:10,padding:12}}>
                      <div style={{fontSize:10,color:"#555",marginBottom:6,textTransform:"uppercase",letterSpacing:"1px"}}>AI Image Prompt</div>
                      <div style={{fontSize:12,color:"#ccc",lineHeight:1.6,fontFamily:"monospace"}}>{img.midjourney_prompt}</div>
                    </div>
                    <button className="btn-ghost" style={{width:"100%",marginTop:10,fontSize:12}}
                      onClick={()=>copyText(img.midjourney_prompt,`img-${i}`)}>
                      {copied===`img-${i}`?"✓ Copied!":"Copy Prompt"}
                    </button>
                  </div>
                ))}
              </div>
            )}
            <div style={{display:"flex",gap:12,marginTop:28}}>
              <button className="btn-ghost" onClick={()=>setStep(1)}>← Back</button>
              <button className="btn-primary" style={{flex:1,padding:"14px"}}
                onClick={()=>{ generatePlatformPosts(); setStep(3); }}>
                Next: Distribute →
              </button>
            </div>
          </div>
        )}

        {/* ── STEP 3 ── */}
        {step===3&&(
          <div className="fade-in">
            <div style={{marginBottom:20}}>
              <div style={{fontFamily:"'Syne',sans-serif",fontSize:22,fontWeight:800}}>
                Auto-<span style={{color:"#f97316"}}>Post</span>
              </div>
              <div style={{color:"#666",fontSize:13,marginTop:6}}>Connect your accounts and post in one click.</div>
            </div>

            <div style={{marginBottom:16}}>
              <div style={{fontSize:11,color:"#888",marginBottom:10,textTransform:"uppercase",letterSpacing:"1px"}}>Select Platforms</div>
              <div style={{display:"flex",flexWrap:"wrap",gap:8}}>
                {PLATFORMS.map(p=>(
                  <div key={p.id} className={`chip ${selectedPlatforms.includes(p.id)?"active":""}`}
                    onClick={()=>togglePlatform(p.id)}>
                    <span style={{fontWeight:700,color:selectedPlatforms.includes(p.id)?p.color:"#555"}}>{p.icon}</span>
                    {p.label}
                  </div>
                ))}
              </div>
            </div>

            {!platformPosts&&(
              <button className="btn-primary" style={{width:"100%",marginBottom:20}} disabled={loading} onClick={generatePlatformPosts}>
                {loading?"⚡ Writing posts…":"Generate Posts →"}
              </button>
            )}

            {loading&&!platformPosts&&(
              <div style={{textAlign:"center",padding:40}}>
                <div className="pulse" style={{fontSize:32,marginBottom:10}}>⚡</div>
                <div style={{color:"#555",fontSize:13}}>Writing platform-native posts…</div>
              </div>
            )}

            {platformPosts&&(
              <>
                {/* Post-All banner */}
                <div style={{background:"linear-gradient(135deg,rgba(249,115,22,.12),rgba(236,72,153,.12))",
                  border:"1px solid rgba(249,115,22,.25)",borderRadius:14,padding:"16px 20px",
                  display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:16,gap:12,flexWrap:"wrap"}}>
                  <div>
                    <div style={{fontFamily:"'Syne',sans-serif",fontWeight:800,fontSize:15}}>🚀 Post to All Platforms</div>
                    <div style={{fontSize:12,color:"#888",marginTop:4}}>
                      {selectedPlatforms.filter(id=>hasCreds(id)&&PLATFORMS.find(p=>p.id===id)?.apiMode!=="clipboard").length} API-connected ·{" "}
                      {selectedPlatforms.filter(id=>PLATFORMS.find(p=>p.id===id)?.apiMode==="clipboard").length} clipboard ·{" "}
                      {selectedPlatforms.filter(id=>!hasCreds(id)&&PLATFORMS.find(p=>p.id===id)?.apiMode!=="clipboard").length} need keys
                    </div>
                  </div>
                  <button className="post-btn" onClick={autoPostAll}>Post All Now</button>
                </div>

                {/* Per-platform */}
                <div style={{display:"flex",flexDirection:"column",gap:14}} className="fade-in">
                  {PLATFORMS.filter(p=>selectedPlatforms.includes(p.id)&&platformPosts[p.id]).map(p=>(
                    <div key={p.id} className="card">
                      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
                        <div style={{display:"flex",alignItems:"center",gap:10}}>
                          <div style={{width:36,height:36,borderRadius:10,background:`${p.color}22`,
                            display:"flex",alignItems:"center",justifyContent:"center",
                            fontSize:15,fontWeight:900,color:p.color}}>{p.icon}</div>
                          <div>
                            <div style={{fontFamily:"'Syne',sans-serif",fontWeight:700,fontSize:14}}>{p.label}</div>
                            <div style={{fontSize:11,color:"#555",marginTop:1}}>
                              {p.apiMode==="clipboard" ? "clipboard + deeplink" : hasCreds(p.id) ? "✓ connected" : "not connected — click + Connect"}
                            </div>
                          </div>
                        </div>
                        <div style={{display:"flex",gap:8,alignItems:"center"}}>
                          <StatusBadge id={p.id}/>
                          {p.apiMode!=="clipboard"&&(
                            <button className="btn-ghost" style={{fontSize:11,padding:"5px 12px"}}
                              onClick={()=>openSettings(p.id)}>
                              {hasCreds(p.id)?"⚙ Keys":"+ Connect"}
                            </button>
                          )}
                        </div>
                      </div>

                      <div style={{background:"rgba(0,0,0,.3)",borderRadius:10,padding:14,
                        fontSize:13,color:"#ccc",lineHeight:1.7,whiteSpace:"pre-wrap",marginBottom:12,
                        borderLeft:`3px solid ${p.color}55`}}>
                        {platformPosts[p.id]}
                      </div>

                      {postError[p.id]&&(
                        <div style={{background:"rgba(239,68,68,.1)",border:"1px solid rgba(239,68,68,.2)",
                          borderRadius:8,padding:"8px 12px",fontSize:12,color:"#fca5a5",marginBottom:10,lineHeight:1.6}}>
                          ✗ {postError[p.id]}
                          {p.id==="twitter"&&<span style={{color:"#777",display:"block",marginTop:4}}>💡 Twitter's API blocks browser-side OAuth. You'll need a small server proxy (Node.js/Cloudflare Worker) to sign requests. Use "Copy" + open Twitter for now.</span>}
                          {p.id==="linkedin"&&<span style={{color:"#777",display:"block",marginTop:4}}>💡 LinkedIn blocks cross-origin requests in browsers. Use a CORS proxy or backend endpoint in production.</span>}
                        </div>
                      )}

                      <div style={{display:"flex",gap:8}}>
                        <button className="btn-ghost" style={{flex:1,fontSize:12}}
                          onClick={()=>copyText(platformPosts[p.id],p.id)}>
                          {copied===p.id?"✓ Copied!":"Copy"}
                        </button>
                        <button className="post-btn" disabled={postStatus[p.id]==="posting"}
                          onClick={()=>autoPost(p.id)}>
                          {postStatus[p.id]==="posting" ? "Posting…" :
                           p.apiMode==="clipboard"       ? `Copy & Open ${p.label}` :
                           hasCreds(p.id)                ? `Post to ${p.label}` :
                                                           "Connect & Post"}
                        </button>
                      </div>
                    </div>
                  ))}
                </div>

                {/* Summary */}
                <div style={{background:"linear-gradient(135deg,rgba(249,115,22,.08),rgba(236,72,153,.08))",
                  border:"1px solid rgba(249,115,22,.18)",borderRadius:14,padding:20,marginTop:16}}>
                  <div style={{fontFamily:"'Syne',sans-serif",fontWeight:800,fontSize:15,marginBottom:10}}>🎯 Campaign Summary</div>
                  <div style={{display:"flex",flexDirection:"column",gap:6,fontSize:13,color:"#aaa"}}>
                    <div>✅ Product: <span style={{color:"#ddd"}}>{product.name}</span></div>
                    <div>✅ Headline: <span style={{color:"#ddd"}}>{ad?.headline}</span></div>
                    <div>✅ Posts ready for {selectedPlatforms.length} platform{selectedPlatforms.length>1?"s":""}</div>
                    {imageIdeas&&<div>✅ {imageIdeas.length} visual concepts generated</div>}
                  </div>
                  <div style={{marginTop:14,display:"flex",gap:8,flexWrap:"wrap"}}>
                    <button className="btn-ghost" style={{fontSize:12}} onClick={()=>{
                      setStep(0); setGeneratedAds(null); setPlatformPosts(null);
                      setImageIdeas(null); setPostStatus({}); setPostError({});
                      setProduct({name:"",desc:"",price:"",audience:""});
                    }}>+ New Campaign</button>
                    <button className="btn-primary" style={{fontSize:12}} onClick={()=>{
                      const s=`AD STUDIO EXPORT\n\nProduct: ${product.name}\nPrice: ${product.price}\n\n=== HEADLINE ===\n${ad?.headline}\n\n=== BODY ===\n${ad?.body}\n\n=== CTA ===\n${ad?.cta}\n\n=== POSTS ===\n${selectedPlatforms.filter(id=>platformPosts?.[id]).map(id=>`\n[${id.toUpperCase()}]\n${platformPosts[id]}`).join("\n")}`;
                      copyText(s,"export");
                    }}>{copied==="export"?"✓ Exported!":"Export All"}</button>
                  </div>
                </div>
              </>
            )}
          </div>
        )}
      </div>
    </div>
  );
}
